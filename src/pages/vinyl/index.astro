---
import vinylData from "../../data/vinyl.generated.json";
import VinylDetailPanel from "../../components/VinylDetailPanel.astro";
import {
  buildSections,
  getDetailHref,
  getListingCover,
  sortRecords,
  type VinylRecord,
} from "../../lib/vinyl";

const title = "vinyl";
const description = "Philip Matthew Ruth vinyl collection";

const records = sortRecords(vinylData.records as VinylRecord[]);
const sections = buildSections(records);
const recordContextById: Record<
  string,
  { previousRecord: VinylRecord | null; nextRecord: VinylRecord | null }
> = Object.fromEntries(
  records.map((record, index) => [
    record.id,
    {
      previousRecord: index > 0 ? records[index - 1] : null,
      nextRecord: index < records.length - 1 ? records[index + 1] : null,
    },
  ]),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="vinyl-page">
      <header class="page-header">
        <a class="back-link" href="/">← philip ruth</a>
        <h1 class="page-title">vinyl</h1>
      </header>

      <div class="catalog-layout">
        <nav class="letter-index" aria-label="jump to artist letter">
          <p class="sr-only" id="active-letter-status" aria-live="polite"></p>
          {
            sections.map(({ letter }) => (
              <a href={`#letter-${letter}`} data-letter-link={letter} class="letter-link">
                {letter}
              </a>
            ))
          }
        </nav>

        <main class="collection">
          {
            sections.map(({ letter, items }) => (
              <section id={`letter-${letter}`} class="letter-section" data-letter-section={letter}>
                <h2 class="sr-only">{letter}</h2>
                <div class="album-grid">
                  {items.map((record) => {
                    const cover = getListingCover(record);

                    return (
                      <article class="album-card">
                        <a
                          class="album-link"
                          href={getDetailHref(record)}
                          data-record-link
                          data-record-id={record.id}
                        >
                          <div class="album-frame">
                            {
                              cover ? (
                                <img
                                  src={cover.src}
                                  alt={`Cover art for ${record.title} by ${record.artist}`}
                                  width={cover.width}
                                  height={cover.height}
                                  loading="lazy"
                                  decoding="async"
                                />
                              ) : null
                            }
                          </div>
                          <div class="album-meta">
                            <h3 class="artist-name">{record.artist}</h3>
                            <p class="album-title">{record.title}</p>
                          </div>
                        </a>
                      </article>
                    );
                  })}
                </div>
              </section>
            ))
          }
        </main>
      </div>
    </div>

    <div class="detail-modal" data-detail-modal hidden>
      <button class="detail-backdrop" type="button" aria-label="Close detail view" data-detail-backdrop>
      </button>
      <div class="detail-modal-shell" role="dialog" aria-modal="true" aria-label="Vinyl record details">
        <div class="detail-modal-panel" data-detail-modal-panel></div>
      </div>
    </div>

    {
      records.map((record) => {
        const { previousRecord, nextRecord } = recordContextById[record.id];

        return (
          <template data-detail-template={record.id}>
            <VinylDetailPanel
              record={record}
              previousRecord={previousRecord}
              nextRecord={nextRecord}
              isModal={true}
            />
          </template>
        );
      })
    }

    <script is:inline src="/scripts/vinyl-detail.js"></script>
    <script is:inline>
      const sectionNodes = Array.from(document.querySelectorAll("[data-letter-section]"));
      const letterLinks = new Map(
        Array.from(document.querySelectorAll("[data-letter-link]")).map((link) => [
          link.dataset.letterLink,
          link,
        ]),
      );
      const activeLetterStatus = document.querySelector("#active-letter-status");
      let activeLetter = "";

      const setActiveLetter = (letter) => {
        if (!letter || activeLetter === letter) return;
        activeLetter = letter;
        letterLinks.forEach((link, key) => {
          const isActive = key === letter;
          link.classList.toggle("is-active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "true");
          } else {
            link.removeAttribute("aria-current");
          }
        });
        if (activeLetterStatus) {
          activeLetterStatus.textContent = `section ${letter}`;
        }
      };

      const syncActiveLetter = () => {
        const threshold = Math.max(72, window.innerHeight * 0.18);
        let currentLetter = sectionNodes[0]?.dataset.letterSection ?? "";

        sectionNodes.forEach((section) => {
          if (section.getBoundingClientRect().top <= threshold) {
            currentLetter = section.dataset.letterSection;
          }
        });

        setActiveLetter(currentLetter);
      };

      window.addEventListener("scroll", syncActiveLetter, { passive: true });
      window.addEventListener("resize", syncActiveLetter);
      letterLinks.forEach((link, letter) => {
        link.addEventListener("click", () => setActiveLetter(letter));
      });
      syncActiveLetter();

      const pagePath = "/vinyl/";
      const modal = document.querySelector("[data-detail-modal]");
      const modalPanel = document.querySelector("[data-detail-modal-panel]");
      const backdrop = document.querySelector("[data-detail-backdrop]");
      const html = document.documentElement;
      const body = document.body;
      const recordLinks = new Map(
        Array.from(document.querySelectorAll("[data-record-link]")).map((link) => [
          link.dataset.recordId,
          link,
        ]),
      );
      let lastFocusedLink = null;

      if (!history.state?.view) {
        history.replaceState({ view: "grid" }, "", pagePath);
      }

      const showModal = () => {
        if (!(modal instanceof HTMLElement)) return;
        modal.hidden = false;
        modal.classList.add("is-open");
        html.classList.add("is-detail-open");
        body.classList.add("is-detail-open");
      };

      const hideModal = ({ restoreFocus = true } = {}) => {
        if (!(modal instanceof HTMLElement) || !(modalPanel instanceof HTMLElement)) return;
        modal.classList.remove("is-open");
        modal.hidden = true;
        modalPanel.replaceChildren();
        html.classList.remove("is-detail-open");
        body.classList.remove("is-detail-open");
        if (restoreFocus && lastFocusedLink instanceof HTMLElement) {
          lastFocusedLink.focus();
        }
      };

      const closeModal = () => {
        if (history.state?.view === "record") {
          history.back();
          return;
        }

        hideModal();
        history.replaceState({ view: "grid" }, "", pagePath);
      };

      const renderRecord = (recordId, { navigationMode = "none", sourceLink = null } = {}) => {
        if (!(modalPanel instanceof HTMLElement) || !(modal instanceof HTMLElement)) return;

        const recordLink = recordLinks.get(recordId);
        const template = document.querySelector(`[data-detail-template="${recordId}"]`);

        if (!(recordLink instanceof HTMLAnchorElement) || !(template instanceof HTMLTemplateElement)) {
          console.error(`Unable to render vinyl detail for ${recordId}`);
          return;
        }

        if (sourceLink instanceof HTMLAnchorElement) {
          lastFocusedLink = sourceLink;
        } else if (!(lastFocusedLink instanceof HTMLAnchorElement)) {
          lastFocusedLink = recordLink;
        }

        modalPanel.replaceChildren(template.content.cloneNode(true));
        showModal();
        window.VinylDetail?.initialize(modalPanel);

        const panelRoot = modalPanel.querySelector("[data-vinyl-detail-root]");
        if (panelRoot instanceof HTMLElement) {
          panelRoot.focus();
        }

        const href = recordLink.getAttribute("href");
        const state = { view: "record", recordId };

        if (navigationMode === "push") {
          history.pushState(state, "", href);
        }

        if (navigationMode === "replace") {
          history.replaceState(state, "", href);
        }
      };

      modalPanel?.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.closest("[data-modal-close]")) {
          event.preventDefault();
          closeModal();
          return;
        }

        const navLink = target.closest("[data-record-nav]");

        if (!(navLink instanceof HTMLAnchorElement)) return;
        if (
          event.defaultPrevented ||
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey
        ) {
          return;
        }

        const nextRecordId = navLink.dataset.recordId;

        if (!nextRecordId) return;
        event.preventDefault();
        renderRecord(nextRecordId, { navigationMode: "replace" });
      });

      recordLinks.forEach((link, recordId) => {
        link.addEventListener("click", (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }

          event.preventDefault();
          renderRecord(recordId, {
            navigationMode: "push",
            sourceLink: event.currentTarget,
          });
        });
      });

      backdrop?.addEventListener("click", closeModal);

      document.addEventListener("keydown", (event) => {
        if (event.key !== "Escape") return;
        if (!(modal instanceof HTMLElement) || !modal.classList.contains("is-open")) return;
        event.preventDefault();
        closeModal();
      });

      window.addEventListener("popstate", (event) => {
        const state = event.state;
        if (state?.view === "record" && typeof state.recordId === "string") {
          renderRecord(state.recordId, { navigationMode: "none" });
          return;
        }

        hideModal();
      });
    </script>
  </body>
</html>

<style>
  @font-face {
    font-family: "Signifier";
    src: url("/fonts/signifier/Signifier-Regular.ttf") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Signifier";
    src: url("/fonts/signifier/Signifier-RegularItalic.ttf") format("truetype");
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }
  :root {
    color-scheme: light dark;
    --background: #f5f5f5;
    --text: #1a1a1a;
    --text-muted: rgb(153 153 153 / 100%);
    --rule: #e8e8e8;
    --section-rule: #d0d0d0;
    --surface: #ebebeb;
    --header-spacing: 1.5rem;
    --header-font-size: clamp(1.2rem, 3vmin, 2em);
    --detail-backdrop: rgb(245 245 245 / 74%);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --background: #121212;
      --text: #e0e0e0;
      --text-muted: #666666;
      --rule: #3d3d3d;
      --section-rule: #4a4a4a;
      --surface: #2d2d2d;
      --detail-backdrop: rgb(18 18 18 / 74%);
    }
  }
  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--background);
    color: var(--text);
  }
  html.is-detail-open,
  body.is-detail-open {
    overflow: hidden;
  }
  body {
    font-family: "Signifier", serif;
  }
  .vinyl-page {
    min-height: 100vh;
    padding: var(--header-spacing);
  }
  .page-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--header-spacing);
    margin-bottom: 2rem;
  }
  .back-link,
  .page-title {
    margin: 0;
    color: inherit;
    font-size: var(--header-font-size);
    font-weight: 400;
    line-height: 1;
  }
  .back-link {
    text-decoration: none;
  }
  .back-link:hover,
  .back-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .catalog-layout {
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    align-items: start;
    column-gap: 1rem;
  }
  .letter-index {
    position: sticky;
    top: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 0.55rem;
    align-items: flex-start;
  }
  .letter-link {
    color: var(--text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    font-size: 0.92rem;
    letter-spacing: 0.08em;
    line-height: 1;
  }
  .letter-link:hover,
  .letter-link:focus-visible {
    color: var(--text);
    border-color: currentColor;
    outline: none;
  }
  .letter-link.is-active {
    color: var(--text);
    border-color: currentColor;
  }
  .collection {
    display: grid;
    gap: 0;
  }
  .letter-section {
    display: grid;
    gap: 0;
    scroll-margin-top: 6rem;
    margin-top: 1.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--section-rule);
  }
  .letter-section:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }
  .album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
    gap: 1.5rem 1.25rem;
  }
  .album-card {
    min-width: 0;
  }
  .album-link {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }
  .album-frame {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--surface);
  }
  .album-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .album-meta {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }
  .artist-name,
  .album-title {
    margin: 0;
  }
  .artist-name {
    font-size: clamp(1.05rem, 2.6vmin, 1.22rem);
    line-height: 1.15;
    font-weight: 400;
  }
  .album-title {
    min-width: 0;
    overflow: hidden;
    color: var(--text-muted);
    font-size: clamp(0.92rem, 2.2vmin, 1rem);
    text-overflow: ellipsis;
    white-space: nowrap;
    font-style: italic;
  }
  .album-link:hover .artist-name,
  .album-link:focus-visible .artist-name {
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }
  .album-link:focus-visible {
    outline: none;
  }
  .detail-modal[hidden] {
    display: none;
  }
  .detail-modal {
    position: fixed;
    inset: 0;
    z-index: 20;
    display: grid;
    align-items: center;
    justify-items: center;
    padding: 1rem;
  }
  .detail-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: var(--detail-backdrop);
    backdrop-filter: blur(10px);
    cursor: pointer;
  }
  .detail-modal-shell {
    position: relative;
    z-index: 1;
    width: min(100%, 78rem);
    height: min(calc(100vh - 2rem), 44rem);
    overflow: hidden;
  }
  .detail-modal-panel {
    width: 100%;
    height: 100%;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (min-width: 48rem) {
    .catalog-layout {
      grid-template-columns: 1.5rem minmax(0, 1fr);
      column-gap: 2rem;
    }
    .letter-index {
      top: 1.5rem;
    }
    .album-grid {
      grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
      gap: 2rem 1.5rem;
    }
    .vinyl-page {
      padding: 2rem;
      padding-top: 1.5rem;
    }
  }
  @media (min-width: 72rem) {
    .album-grid {
      grid-template-columns: repeat(auto-fill, minmax(13.5rem, 1fr));
      gap: 2.25rem 1.75rem;
    }
  }
  @media (max-width: 47.999rem) {
    .detail-modal {
      padding: 0;
    }
    .detail-backdrop {
      background: var(--background);
      backdrop-filter: none;
    }
    .detail-modal-shell {
      width: 100%;
      height: 100%;
      max-height: none;
    }
  }
</style>
